# --- Server ---
PORT=4000
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=120
MAX_UPLOAD_SIZE_MB=50

# --- PostgreSQL ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kurate
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=kurate
PG_POOL_MAX=10

# --- kurate-parser (Python/FastAPI microservice) ---
PARSER_SERVICE_URL=http://localhost:8000
PARSER_TIMEOUT_MS=300000